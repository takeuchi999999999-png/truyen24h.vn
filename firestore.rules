rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Users Collection
    match /users/{userId} {
      // Cho phép đọc thông tin user công khai
      allow read: if true;
      
      // Cho phép user tự sửa thông tin CỦA MÌNH
      // Coins chỉ được GIẢM (trả xu khi unlock/donate), KHÔNG được tự cộng
      allow write: if request.auth != null && request.auth.uid == userId 
                   && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'email', 'unlockedChapters', 'donateQR', 'lastCheckIn', 'coins', 'contributionScore', 'badges']))
                   && (
                     !request.resource.data.diff(resource.data).affectedKeys().hasAny(['coins'])
                     || request.resource.data.coins <= resource.data.coins
                   );
    }

    // 2. Cho phép CỘNG xu cho tác giả khi mua chương/donate
    // Chỉ cho phép: user đã đăng nhập + chỉ sửa field coins + coins tăng lên (increment)
    // + KHÔNG được tự cộng cho CHÍNH MÌNH (ngăn exploit)
    match /users/{authorId} {
       allow update: if request.auth != null 
                     && request.auth.uid != authorId
                     && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coins'])
                     && request.resource.data.coins > resource.data.coins;
    }

    // 3. Truyện (Novels)
    match /novels/{novelId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
      
      // Chương truyện (Chapters)
      match /chapters/{chapterId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/novels/$(novelId)).data.authorId == request.auth.uid;
        
        // Inline Comments
        match /inline_comments/{commentId} {
          allow read: if true;
          allow create: if request.auth != null;
          allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
        }
      }
    }

    // 4. Lịch sử Giao Dịch
    match /transactions/{txId} {
      allow read: if request.auth != null && (resource.data.buyerId == request.auth.uid || resource.data.authorId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.buyerId == request.auth.uid;
      allow update, delete: if false;
    }

    // 5. Lệnh rút tiền
    match /withdraw_requests/{reqId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'PENDING';
      allow update, delete: if false;
    }

    // 6. Blog posts — đọc công khai. Ghi/sửa/xoá chỉ qua Admin SDK
    // (Admin SDK bypass rules) hoặc người dùng đã login (kiểm soát thêm
    // bằng email whitelist phía server route).
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
